# Later Text2Voice — Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in all values below
#   3. For Lambda, paste each key-value pair into:
#      Lambda → your function → Configuration → Environment variables
#
# Never commit your .env file to git — it contains secrets.

# ── Raindrop.io ───────────────────────────────────────────────────────────────
# Get this at: https://app.raindrop.io/settings/integrations
# Scroll down to "For Developers" → click "Create test token"
RAINDROPTOKEN=your_raindrop_test_token_here

# The exact name of the tag you use in Raindrop.io (case-sensitive)
LATERTAG=Later

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Your Gmail address — used both to SEND and RECEIVE the audio files
GMAILADDRESS=you@gmail.com

# A Gmail App Password (NOT your regular Gmail password)
# How to get one (takes 2 minutes):
#   1. Go to myaccount.google.com → Security → 2-Step Verification (enable if off)
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. App name: "Later T2S" → click Create → copy the 16-character code
#   4. Paste it here (spaces are fine — Google includes them for readability)
GMAILPASSWORD=xxxx xxxx xxxx xxxx

# ── AWS / DynamoDB ────────────────────────────────────────────────────────────
# The DynamoDB table name you created during setup
DBTABLE=text2voice_items

# ── AWS Polly (text-to-speech) ────────────────────────────────────────────────
# Voice used for narration. Options: Joanna, Matthew, Amy, Brian, Emma, Kendra...
# Full list: https://docs.aws.amazon.com/polly/latest/dg/voicelist.html
POLLYVOICE=Joanna

# Engine: "standard" works in all AWS regions. "neural" sounds more natural but
# is only available in select regions (us-east-1, us-west-2, eu-west-1).
POLLYENGINE=standard

# ── Optional Tuning ───────────────────────────────────────────────────────────
# How many minutes to wait after the first bookmark before processing the batch
BATCHDELAY=5

# Max characters per article before truncating (prevents Lambda timeouts on huge PDFs)
MAXCHARS=8000
